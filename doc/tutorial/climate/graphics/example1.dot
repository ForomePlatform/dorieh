"extract_year" [fillcolor=lightgoldenrodyellow, style=filled, label="extract_year", shape=record];
"get_shapes" [fillcolor=lightgoldenrodyellow, style=filled, label="get_shapes", shape=record];
"extract_year" -> "get_shapes";
"aggregate" [fillcolor=lightgoldenrodyellow, style=filled, label=aggregate, shape=record];
"ingest" [fillcolor=lightgoldenrodyellow, style=filled, label=ingest, shape=record];
"aggregate" -> "ingest";
"initdb" [fillcolor=lightgoldenrodyellow, style=filled, label=initdb, shape=record];
"ingest" [fillcolor=lightgoldenrodyellow, style=filled, label=ingest, shape=record];
"initdb" -> "ingest";
subgraph cluster_inputs {
rank=same;
style=dashed;
label="Workflow Inputs";
"band" [fillcolor="#94DDF4", style=filled, label=band, shape=record];
"band" [fillcolor="#94DDF4", style=filled, label=band, shape=record];
"date" [fillcolor="#94DDF4", style=filled, label=date, shape=record];
"date" [fillcolor="#94DDF4", style=filled, label=date, shape=record];
"geography" [fillcolor="#94DDF4", style=filled, label=geography, shape=record];
"geography" [fillcolor="#94DDF4", style=filled, label=geography, shape=record];
"connection_name" [fillcolor="#94DDF4", style=filled, label="connection_name", shape=record];
"connection_name" [fillcolor="#94DDF4", style=filled, label="connection_name", shape=record];
"connection_name" [fillcolor="#94DDF4", style=filled, label="connection_name", shape=record];
"connection_name" [fillcolor="#94DDF4", style=filled, label="connection_name", shape=record];
"database" [fillcolor="#94DDF4", style=filled, label=database, shape=record];
"database" [fillcolor="#94DDF4", style=filled, label=database, shape=record];
"database" [fillcolor="#94DDF4", style=filled, label=database, shape=record];
"database" [fillcolor="#94DDF4", style=filled, label=database, shape=record];
}
"band" -> "aggregate";
"band" -> "download";
"date" -> "aggregate";
"date" -> "extract_year";
"geography" -> "aggregate";
"geography" -> "get_shapes";
"connection_name" -> "build_gold";
"connection_name" -> "build_silver";
"connection_name" -> "ingest";
"connection_name" -> "initdb";
"database" -> "build_gold";
"database" -> "build_silver";
"database" -> "ingest";
"database" -> "initdb";
subgraph cluster_outputs {
rank=same;
style=dashed;
label="Workflow Outputs";
labelloc=b;
"aggregate_data" [fillcolor="#94DDF4", style=filled, label="aggregate_data", shape=record];
"aggregate_errors" [fillcolor="#94DDF4", style=filled, label="aggregate_errors", shape=record];
"aggregate_log" [fillcolor="#94DDF4", style=filled, label="aggregate_log", shape=record];
"build_gold_err" [fillcolor="#94DDF4", style=filled, label="build_gold_err", shape=record];
