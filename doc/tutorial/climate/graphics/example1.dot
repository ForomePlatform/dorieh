"ingest_log" [fillcolor="#94DDF4", style=filled, label="ingest_log", shape=record];
"initdb_err" [fillcolor="#94DDF4", style=filled, label="initdb_err", shape=record];
"initdb_log" [fillcolor="#94DDF4", style=filled, label="initdb_log", shape=record];
}
"aggregate" -> "aggregate_data";
"aggregate" -> "aggregate_errors";
"aggregate" -> "aggregate_log";
"build_gold" -> "build_gold_err";
"build_gold" -> "build_gold_log";
"build_silver" -> "build_silver_err";
"build_silver" -> "build_silver_log";
